{
  "manifest_version": 3,
  "name": "Fake LinkedIn Profile Detector",
  "version": "1.0",
  "description": "Detects fake LinkedIn profiles using Machine Learning",
  
  "permissions": ["activeTab", "scripting"],
  
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"]
    }
  ]
}